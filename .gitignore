# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/

# Virtual env / local env
.venv/
venv/
env/
.env
.env.*

# Google Drive 上传：敏感凭证与 token，禁止入库
**/client_secrets*.json
**/.gdrive_token*.json
**/gdrive_token*.json
**/credentials.json

# Logs and runtime files
logs/
log/
*.log

# Common temp/backup files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Office temp docs (lock files)
~$*.docx
~$*.xlsx
~$*.pptx

# Keep generated docs out of git (uncomment if needed)
# *.pdf
# *.docx
# *.xlsx
# *.pptx

# --- 2026 project: do not commit ---
2026/logs/
2026/log/
2026/.tmp_test_work/
2026/.venv/
2026/.python/
2026/__pycache__/
2026/.pytest_cache/
2026/.mypy_cache/
2026/.ruff_cache/
2026/.coverage
2026/.coverage.*
2026/config.json
2026/config_profiles/
2026/config_profiles/*.json
2026/tasks/
2026/tasks/*.json
2026/tasks/tasks_index.json
2026/output/
2026/skills/
2026/out.txt
2026/2026.code-workspace
2026/.cursor/mcp.json
2026/.cursor/settings.json
# PyInstaller
2026/build/
2026/dist/
2026/*.spec
# Root-level docs should live under docs/
2026/*.md
!2026/README.md
!2026/CHANGELOG.md
!2026/AGENTS.md
# Repo-root temp scripts (e.g. _patch_*.py, _fix_*.py)
_*.py
_*.txt
# 别误伤包初始化文件
!__init__.py
