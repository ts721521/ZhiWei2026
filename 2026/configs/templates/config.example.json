{
  "_meta": {
    "config_kind": "template",
    "template_group": "config.example.json",
    "template_name": "config.example",
    "description": "基线模板配置，用于手动创建运行配置的起点。",
    "last_updated": "2026-02-28",
    "notes": [
      "复制此模板并填写本地 source/target 路径。",
      "根据场景调整运行模式与输出开关。"
    ]
  },
  "source_folder": "C:\\YourSourcePath",
  "target_folder": "D:\\YourOutputPath",
  "log_folder": "./logs",
  "obsidian_sync_enabled": true,
  "obsidian_root": "T:\\AI",
  "obsidian_program_name": "ZhiWei",
  "enable_sandbox": true,
  "default_engine": "wps",
  "kill_process_mode": "auto",
  "enable_failed_file_trace_log": true,
  "run_mode": "convert_then_merge",
  "enable_merge": true,
  "output_enable_pdf": true,
  "output_enable_md": true,
  "output_enable_merged": true,
  "output_enable_independent": false,
  "max_merge_size_mb": 80,
  "excluded_folders": [
    "temp",
    "backup",
    "archive"
  ],
  "enable_merge_map": true,
  "bookmark_with_short_id": true,
  "source_folders": [],
  "merge_filename_pattern": "Merged_{category}_{timestamp}_{idx}"
}
